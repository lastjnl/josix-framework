{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body_class %}min-h-screen font-sans bg-[radial-gradient(circle_at_top,#1e293b_0,#020617_52%,#000_100%)] text-gray-200{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 py-12">

    {# ── Header ── #}
    <div class="flex items-center justify-between mb-8">
        <div>
            <div class="inline-flex items-center gap-2 py-0.5 pr-3 pl-0.5 mb-3 rounded-full border border-sky-400/45 bg-slate-900/[.97] text-gray-400 text-[11px] uppercase tracking-wide">
                <span class="inline-flex items-center justify-center w-[18px] h-[18px] rounded-full bg-gradient-to-br from-sky-100 to-sky-400 shadow-[0_0_0_1px_rgba(15,23,42,0.8),0_10px_25px_rgba(56,189,248,0.4)] text-slate-900 text-[11px] font-bold">J</span>
                <span>SQLite Demo</span>
                <span class="w-[7px] h-[7px] rounded-full bg-gradient-to-br from-sky-100 to-sky-400 shadow-[0_0_0_1px_rgba(15,23,42,0.8),0_0_18px_rgba(56,189,248,0.9)]"></span>
            </div>
            <h1 class="text-3xl font-bold tracking-tight">
                <span class="bg-gradient-to-r from-gray-200 via-sky-100 to-sky-400 bg-clip-text text-transparent">Notes</span>
            </h1>
            <p class="text-gray-400 text-sm mt-1">A simple CRUD demo powered by SQLite &amp; the Josix database layer.</p>
        </div>
        <a href="/" class="inline-flex items-center gap-2 px-3 py-2 rounded-full bg-slate-900/50 text-gray-400 text-sm border border-slate-400/35 hover:border-sky-400/45 transition-colors">
            &larr; Home
        </a>
    </div>

    {# ── Create note form ── #}
    <form method="POST" action="/notes"
          class="rounded-2xl p-5 mb-8 border border-slate-400/25 bg-slate-900/60 shadow-[0_12px_40px_rgba(15,23,42,0.6)]">
        <div class="grid gap-3">
            <div>
                <label for="title" class="block text-xs uppercase tracking-widest text-gray-400 mb-1">Title</label>
                <input type="text" id="title" name="title" required placeholder="My note…"
                       class="w-full px-3 py-2 rounded-xl bg-slate-800/80 border border-slate-400/30 text-gray-200 text-sm placeholder-gray-500 outline-none focus:border-sky-400/60 transition-colors">
            </div>
            <div>
                <label for="body" class="block text-xs uppercase tracking-widest text-gray-400 mb-1">Body <span class="normal-case text-gray-500">(optional)</span></label>
                <textarea id="body" name="body" rows="3" placeholder="Write something…"
                          class="w-full px-3 py-2 rounded-xl bg-slate-800/80 border border-slate-400/30 text-gray-200 text-sm placeholder-gray-500 outline-none focus:border-sky-400/60 transition-colors resize-y"></textarea>
            </div>
            <div class="flex justify-end">
                <button type="submit"
                        class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-gradient-to-br from-sky-100 to-sky-400 text-slate-900 text-sm font-medium shadow-[0_0_0_1px_rgba(15,23,42,0.9),0_12px_24px_rgba(56,189,248,0.35)] hover:-translate-y-px hover:shadow-[0_0_0_1px_rgba(15,23,42,0.9),0_14px_30px_rgba(56,189,248,0.45)] transition-all duration-150 cursor-pointer border-none outline-none">
                    + Add note
                </button>
            </div>
        </div>
    </form>

    {# ── Notes list ── #}
    {% if notes is empty %}
        <div class="text-center py-16 text-gray-500">
            <p class="text-lg mb-1">No notes yet.</p>
            <p class="text-sm">Create your first note using the form above.</p>
        </div>
    {% else %}
        <div class="grid gap-3">
            {% for note in notes %}
                <div class="group rounded-2xl p-4 border border-slate-400/20 bg-slate-900/40 hover:border-slate-400/35 transition-colors">
                    <div class="flex items-start justify-between gap-3">
                        <div class="flex-1 min-w-0">
                            <h3 class="text-sm font-medium text-gray-200 truncate">{{ note.title }}</h3>
                            {% if note.body %}
                                <p class="text-xs text-gray-400 mt-1 line-clamp-2">{{ note.body }}</p>
                            {% endif %}
                            <p class="text-[0.7rem] text-gray-500 mt-2">{{ note.created_at }}</p>
                        </div>
                        <form method="POST" action="/notes/{{ note.id }}/delete" class="shrink-0">
                            <button type="submit"
                                    class="opacity-0 group-hover:opacity-100 px-2.5 py-1 rounded-full text-[0.72rem] text-red-400 border border-red-400/30 bg-red-400/5 hover:bg-red-400/15 transition-all cursor-pointer">
                                Delete
                            </button>
                        </form>
                    </div>
                </div>
            {% endfor %}
        </div>

        <p class="text-center text-xs text-gray-500 mt-6">{{ notes|length }} note{{ notes|length != 1 ? 's' : '' }} stored in <code class="font-mono px-1 py-0.5 rounded bg-slate-800/80 border border-slate-400/25 text-[0.7rem]">database/josix.sqlite</code></p>
    {% endif %}
</div>
{% endblock %}
