{% extends 'base.html.twig' %}

{% block title %}{{ title }}{% endblock %}

{% block body_class %}min-h-screen flex items-center justify-center px-4 py-8 font-sans bg-[radial-gradient(circle_at_top,#1e293b_0,#020617_52%,#000_100%)] text-gray-200{% endblock %}

{% block body %}
<div class="w-full max-w-[1040px] grid grid-cols-1 lg:grid-cols-[3fr_2.2fr] gap-7">

    {# ── Left card ── #}
    <section class="relative rounded-[2rem] p-7 border border-slate-400/25 shadow-[0_24px_60px_rgba(15,23,42,0.85)] overflow-hidden
                     bg-[radial-gradient(circle_at_top_left,rgba(56,189,248,0.12),transparent_60%),radial-gradient(circle_at_top_right,rgba(59,130,246,0.1),transparent_55%),linear-gradient(145deg,rgba(15,23,42,0.95),rgba(15,23,42,0.92))]">

        {# pill #}
        <div class="inline-flex items-center gap-2 py-0.5 pr-3 pl-0.5 rounded-full border border-sky-400/45 bg-slate-900/[.97] text-gray-400 text-[11px] uppercase tracking-wide">
            <span class="inline-flex items-center justify-center w-[18px] h-[18px] rounded-full bg-gradient-to-br from-sky-100 to-sky-400 shadow-[0_0_0_1px_rgba(15,23,42,0.8),0_10px_25px_rgba(56,189,248,0.4)] text-slate-900 text-[11px] font-bold">J</span>
            <span>Josix framework</span>
            <span class="w-[7px] h-[7px] rounded-full bg-gradient-to-br from-sky-100 to-sky-400 shadow-[0_0_0_1px_rgba(15,23,42,0.8),0_0_18px_rgba(56,189,248,0.9)]"></span>
        </div>

        {# heading #}
        <h1 class="mt-5 mb-3 text-[clamp(2.4rem,3.1vw,2.9rem)] tracking-tighter leading-tight">
            <span class="bg-gradient-to-r from-gray-200 via-sky-100 via-sky-400 to-blue-300 bg-clip-text text-transparent">Lightweight PHP</span><br>
            built for simplicity.
        </h1>

        <p class="mb-6 max-w-md text-gray-400 text-[0.93rem] leading-relaxed">
            Attribute routing, autowiring DI, models &amp; repositories, Twig + Tailwind — everything you need, nothing you don't.
        </p>

        {# meta pills #}
        <div class="flex flex-wrap gap-2 mb-6 text-[11px] text-gray-400 uppercase tracking-widest">
            <div class="px-2.5 py-1 rounded-full border border-slate-400/35 bg-slate-900/95">Routing</div>
            <div class="px-2.5 py-1 rounded-full border border-slate-400/35 bg-slate-900/95">DI Container</div>
            <div class="px-2.5 py-1 rounded-full border border-slate-400/35 bg-slate-900/95">Models &middot; Repositories</div>
            <div class="px-2.5 py-1 rounded-full border border-slate-400/35 bg-slate-900/95">Twig &middot; Tailwind</div>
            <div class="px-2.5 py-1 rounded-full border border-slate-400/35 bg-slate-900/95">MySQL &middot; SQLite</div>
        </div>

        {# cta #}
        <div class="flex flex-wrap items-center gap-3">
            <a href="/notes"
               class="inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-full bg-gradient-to-br from-sky-100 to-sky-400 text-slate-900 text-sm font-medium shadow-[0_0_0_1px_rgba(15,23,42,0.9),0_16px_32px_rgba(56,189,248,0.42)] hover:-translate-y-px hover:shadow-[0_0_0_1px_rgba(15,23,42,0.9),0_18px_38px_rgba(56,189,248,0.5)] transition-all duration-150 cursor-pointer border-none outline-none no-underline">
                Notes Demo &rarr;
            </a>
            <div class="inline-flex items-center gap-2 px-3 py-2.5 rounded-full bg-slate-900/50 text-gray-500 text-sm border border-slate-400/25">
                Docs coming soon
            </div>
        </div>
    </section>

    {# ── Right panel ── #}
    <aside class="relative h-full rounded-[1.75rem] p-4 pt-5 border border-slate-400/45 shadow-[0_24px_60px_rgba(15,23,42,0.9)] overflow-hidden
                   bg-[radial-gradient(circle_at_0_0,rgba(30,64,175,0.4),transparent_50%),radial-gradient(circle_at_100%_100%,rgba(22,101,52,0.4),transparent_55%),linear-gradient(145deg,rgba(15,23,42,0.96),rgba(15,23,42,0.98))]">

        {# panel header #}
        <div class="flex items-center justify-between mb-4 text-[0.8rem] text-gray-400">
            <div class="inline-flex gap-1.5">
                <span class="w-2 h-2 rounded-full bg-red-500"></span>
                <span class="w-2 h-2 rounded-full bg-orange-500"></span>
                <span class="w-2 h-2 rounded-full bg-green-500"></span>
            </div>
            <div class="text-[0.8rem] text-gray-400">Model &middot; Repository</div>
        </div>

        {# code snippet — Model #}
        <div>
            <div class="flex items-center justify-between mb-2 text-xs text-gray-400">
                <span class="inline-flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-sky-400 shadow-[0_0_10px_rgba(56,189,248,0.85)]"></span>
                    Define a model
                </span>
                <span class="px-2 py-0.5 rounded-full border border-slate-400/50 bg-slate-900/90 text-xs">Note.php</span>
            </div>
            <pre class="m-0 p-3 rounded-2xl bg-slate-900 border border-slate-400/45 shadow-[inset_0_0_0_1px_rgba(15,23,42,0.85)] overflow-x-auto text-[0.78rem] leading-relaxed"><code class="font-mono"><span class="text-gray-500">class</span> <span class="text-sky-300">Note</span> <span class="text-gray-500">extends</span> <span class="text-sky-300">Model</span>
{
    <span class="text-gray-500">public static function</span> <span class="text-emerald-300">tableProperties</span>(): array
    {
        <span class="text-gray-500">return</span> [
            <span class="text-amber-300">'id'</span>    =&gt; <span class="text-amber-300">'int'</span>,
            <span class="text-amber-300">'title'</span> =&gt; <span class="text-amber-300">'string'</span>,
            <span class="text-amber-300">'body'</span>  =&gt; <span class="text-amber-300">'string'</span>,
        ];
    }
}</code></pre>
        </div>

        {# code snippet — Repository #}
        <div class="mt-3">
            <div class="flex items-center justify-between mb-2 text-xs text-gray-400">
                <span class="inline-flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 shadow-[0_0_10px_rgba(52,211,153,0.85)]"></span>
                    Use a repository
                </span>
                <span class="px-2 py-0.5 rounded-full border border-slate-400/50 bg-slate-900/90 text-xs">NoteRepository.php</span>
            </div>
            <pre class="m-0 p-3 rounded-2xl bg-slate-900 border border-slate-400/45 shadow-[inset_0_0_0_1px_rgba(15,23,42,0.85)] overflow-x-auto text-[0.78rem] leading-relaxed"><code class="font-mono"><span class="text-gray-500">class</span> <span class="text-sky-300">NoteRepository</span> <span class="text-gray-500">extends</span> <span class="text-sky-300">AbstractRepository</span>
{
    <span class="text-gray-500">// findAll(), findById(), save(), delete()</span>
    <span class="text-gray-500">// — inherited &amp; ready to use</span>
}</code></pre>
        </div>

        {# code snippet — Controller #}
        <div class="mt-3">
            <div class="flex items-center justify-between mb-2 text-xs text-gray-400">
                <span class="inline-flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-amber-400 shadow-[0_0_10px_rgba(251,191,36,0.85)]"></span>
                    Wire it up
                </span>
                <span class="px-2 py-0.5 rounded-full border border-slate-400/50 bg-slate-900/90 text-xs">NoteController.php</span>
            </div>
            <pre class="m-0 p-3 rounded-2xl bg-slate-900 border border-slate-400/45 shadow-[inset_0_0_0_1px_rgba(15,23,42,0.85)] overflow-x-auto text-[0.78rem] leading-relaxed"><code class="font-mono"><span class="text-violet-300">#[Route(path: '/notes', method: 'GET')]</span>
<span class="text-gray-500">public function</span> <span class="text-emerald-300">index</span>(): void
{
    $notes = $this-&gt;notes-&gt;<span class="text-emerald-300">findAll</span>();

    <span class="text-gray-500">echo</span> $this-&gt;twig-&gt;<span class="text-emerald-300">render</span>(
        <span class="text-amber-300">'notes.html.twig'</span>,
        [<span class="text-amber-300">'notes'</span> =&gt; $notes]
    );
}</code></pre>
        </div>

        {# panel footer #}
        <div class="mt-4 pt-2.5 border-t border-dashed border-slate-400/50 flex justify-between items-center text-xs text-gray-400">
            <span>Model → Hydrator → Repository → Controller</span>
        </div>
    </aside>
</div>
{% endblock %}

