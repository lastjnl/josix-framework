{
    "name": "joslast/josix-framework",
    "description": "Light PHP framework core (routing, DI, ORM, env, database)",
    "type": "library",
    "autoload": {
        "psr-4": {
            "Josix\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/josix"
    ],
    "authors": [
        {
            "name": "Jos Last",
            "email": "joslast96@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "twig/twig": "^3.23"
    },
    "require-dev": {
        "symfony/var-dumper": "^8.0",
        "phpunit/phpunit": "^13",
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^4.0",
        "phpmd/phpmd": "^2.15",
        "friendsofphp/php-cs-fixer": "^3.94"
    },
    "scripts": {
        "test:phpunit": "./vendor/bin/phpunit tests",
        "phpcs:analyse": "php-cs-fixer fix --dry-run --diff",
        "phpcs:fix":  "php-cs-fixer fix",
        "phpmd:analyse":    "phpmd app/ text cleancode,codesize,naming,unusedcode",
        "phpstan:analyse":    "phpstan analyse",
        "josix:db:init": "php bin/josix db:init",
        "josix:doctor": "php bin/josix doctor",
        "josix:live": "php bin/josix live",
        "josix:restart": "php bin/josix restart",
        "josix:sync": "php bin/josix sync",
        "josix:stop": "php bin/josix stop"
    }
}
