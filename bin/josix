#!/usr/bin/env php
<?php

declare(strict_types=1);

$rootDir     = dirname(__DIR__);          // .../josix-framework
$composeFile = $rootDir . '/docker-compose.yml';

if (!is_file($composeFile)) {
    fwrite(STDERR, "Error: no docker-compose.yml found in:\n  {$rootDir}\n");
    exit(1);
}

function readEnvValue(string $envFile, string $key): ?string
{
    if (!is_file($envFile)) {
        return null;
    }

    $lines = file($envFile, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES);
    if ($lines === false) {
        return null;
    }

    foreach ($lines as $line) {
        $line = trim($line);

        if ($line === '' || str_starts_with($line, '#')) {
            continue;
        }

        [$k, $v] = array_pad(explode('=', $line, 2), 2, null);
        if ($k === $key && $v !== null) {
            return trim($v);
        }
    }

    return null;
}

function appendEnvDefaultsIfMissing(string $envFile): void
{
    $contents = is_file($envFile) ? (string) file_get_contents($envFile) : '';

    if ($contents !== '' && !str_ends_with($contents, "\n")) {
        $contents .= "\n";
    }

    if (readEnvValue($envFile, 'DB_DRIVER') === null) {
        $contents .= "DB_DRIVER=sqlite\n";
    }

    if (readEnvValue($envFile, 'DB_PATH') === null) {
        $contents .= "DB_PATH=database/josix.sqlite\n";
    }

    file_put_contents($envFile, $contents);
}

/**
 * Validate Docker can see the project directory through bind mounts.
 */
function canDockerMountProject(string $rootDir): bool
{
    $mount = escapeshellarg($rootDir . ':/workspace');
    $probe = escapeshellarg('test -d /workspace/public');
    $cmd   = "docker run --rm -v {$mount} php:8.3-cli sh -lc {$probe} >/dev/null 2>&1";

    exec($cmd, $output, $exitCode);

    return $exitCode === 0;
}

function isJosixContainerRunning(string $rootDir): bool
{
    $cmd = 'cd ' . escapeshellarg($rootDir) . ' && docker compose ps -q josix_example 2>/dev/null';

    exec($cmd, $output, $exitCode);

    if ($exitCode !== 0) {
        return false;
    }

    return trim(implode("\n", $output)) !== '';
}

function getHostManifest(string $rootDir): array
{
    $paths = ['app', 'public', 'templates', 'bin'];
    $manifest = [];

    foreach ($paths as $path) {
        $absolutePath = $rootDir . '/' . $path;
        if (!is_dir($absolutePath)) {
            continue;
        }

        $iterator = new RecursiveIteratorIterator(
            new RecursiveDirectoryIterator($absolutePath, FilesystemIterator::SKIP_DOTS)
        );

        foreach ($iterator as $file) {
            if (!$file->isFile()) {
                continue;
            }

            $relativePath = ltrim(str_replace($rootDir, '', $file->getPathname()), '/');
            $hash = sha1_file($file->getPathname());

            if ($hash !== false) {
                $manifest[$relativePath] = $hash;
            }
        }
    }

    ksort($manifest);

    return $manifest;
}

function getContainerManifest(string $rootDir): array
{
    $shell = <<<'SH'
cd /var/www || exit 1
find app public templates bin -type f -print0 2>/dev/null | sort -z | xargs -0 sha1sum
SH;

    $cmd = 'cd ' . escapeshellarg($rootDir) . ' && docker compose exec -T josix_example sh -lc ' . escapeshellarg($shell);

    exec($cmd, $output, $exitCode);

    if ($exitCode !== 0) {
        return [];
    }

    $manifest = [];
    foreach ($output as $line) {
        if (!preg_match('/^([a-f0-9]{40})\s+(.+)$/', trim($line), $matches)) {
            continue;
        }

        $path = ltrim($matches[2], './');
        $manifest[$path] = $matches[1];
    }

    ksort($manifest);

    return $manifest;
}

function syncProjectToContainer(string $rootDir): int
{
    if (!isJosixContainerRunning($rootDir)) {
        fwrite(STDERR, "josix_example is not running. Start it with composer josix:live first.\n");
        return 1;
    }

    $copies = [
        [$rootDir . '/app/.', 'josix_example:/var/www/app'],
        [$rootDir . '/public/.', 'josix_example:/var/www/public'],
        [$rootDir . '/templates/.', 'josix_example:/var/www/templates'],
        [$rootDir . '/bin/.', 'josix_example:/var/www/bin'],
    ];

    if (is_file($rootDir . '/.env')) {
        $copies[] = [$rootDir . '/.env', 'josix_example:/var/www/.env'];
    }

    foreach ($copies as [$source, $target]) {
        $cmd = 'docker cp ' . escapeshellarg($source) . ' ' . escapeshellarg($target) . ' 2>/dev/null';
        passthru($cmd, $exitCode);

        if ($exitCode !== 0) {
            fwrite(STDERR, "Failed to sync {$source} -> {$target}\n");
            return $exitCode;
        }
    }

    fwrite(STDOUT, "Synced app/, public/, templates/, bin/" . (is_file($rootDir . '/.env') ? ', .env' : '') . " into josix_example.\n");

    return 0;
}

function runDoctor(string $rootDir): int
{
    $hasIssues = false;

    if (canDockerMountProject($rootDir)) {
        fwrite(STDOUT, "[ok] Docker can see {$rootDir} through bind mount.\n");
    } else {
        fwrite(STDERR, "[fail] Docker cannot see {$rootDir} through bind mount.\n");
        $hasIssues = true;
    }

    if (!isJosixContainerRunning($rootDir)) {
        fwrite(STDERR, "[fail] josix_example container is not running. Start it with composer josix:live.\n");
        return 1;
    }

    fwrite(STDOUT, "[ok] josix_example container is running.\n");

    $hostManifest = getHostManifest($rootDir);
    $containerManifest = getContainerManifest($rootDir);

    if ($containerManifest === []) {
        fwrite(STDERR, "[fail] Could not read container manifest.\n");
        return 1;
    }

    $mismatches = [];
    foreach ($hostManifest as $path => $hash) {
        if (!isset($containerManifest[$path]) || $containerManifest[$path] !== $hash) {
            $mismatches[] = $path;
        }
    }

    if ($mismatches === []) {
        fwrite(STDOUT, "[ok] Host and container files match for app/, public/, templates/, and bin/.\n");
    } else {
        fwrite(STDERR, "[fail] Host/container file drift detected.\n");
        foreach (array_slice($mismatches, 0, 10) as $path) {
            fwrite(STDERR, "  - {$path}\n");
        }

        if (count($mismatches) > 10) {
            fwrite(STDERR, '  ... and ' . (count($mismatches) - 10) . " more\n");
        }

        fwrite(STDERR, "Run composer josix:sync to repair the container copy.\n");
        $hasIssues = true;
    }

    return $hasIssues ? 1 : 0;
}

$command = $argv[1] ?? null;

if ($command === null || !in_array($command, ['live', 'restart', 'stop', 'db:init', 'sync', 'doctor'], true)) {
    fwrite(STDERR, "Josix CLI\n\n");
    fwrite(STDERR, "Usage:\n");
    fwrite(STDERR, "  josix live      Start the Josix Framework example stack (docker-compose in this project)\n");
    fwrite(STDERR, "  josix restart   Restart the Josix Framework Docker stack\n");
    fwrite(STDERR, "  josix stop      Stop the Josix Framework Docker stack\n");
    fwrite(STDERR, "  josix db:init   Create local SQLite database file from .env settings\n");
    fwrite(STDERR, "  josix sync      Copy app/public/templates/bin into running container\n");
    fwrite(STDERR, "  josix doctor    Diagnose Docker Desktop bind-mount drift\n\n");
    exit(1);
}

if (($command === 'live' || $command === 'restart') && !canDockerMountProject($rootDir)) {
    fwrite(STDERR, "\033[31m✘ Docker cannot read this project path via bind mount:\033[0m\n");
    fwrite(STDERR, "  {$rootDir}\n\n");
    fwrite(STDERR, "Fix (Docker Desktop):\n");
    fwrite(STDERR, "  1. Settings -> Resources -> File Sharing\n");
    fwrite(STDERR, "  2. Add {$rootDir} (or /var/www)\n");
    fwrite(STDERR, "  3. Apply & Restart Docker Desktop\n");
    fwrite(STDERR, "  4. Run composer josix:live again\n\n");
    fwrite(STDERR, "Alternative: move project under /home/<user>/ and run from there.\n");
    exit(1);
}

switch ($command) {
    case 'doctor':
        exit(runDoctor($rootDir));

    case 'sync':
        exit(syncProjectToContainer($rootDir));

    case 'db:init':
        $envFile = $rootDir . '/.env';
        $envDist = $rootDir . '/.env.dist';

        if (!is_file($envFile) && is_file($envDist)) {
            copy($envDist, $envFile);
            fwrite(STDOUT, "Created .env from .env.dist\n");
        }

        appendEnvDefaultsIfMissing($envFile);

        $driver = strtolower((string) (readEnvValue($envFile, 'DB_DRIVER') ?? 'sqlite'));
        if ($driver !== 'sqlite') {
            fwrite(STDERR, "DB_DRIVER is '{$driver}', not sqlite. Skipping file creation.\n");
            fwrite(STDERR, "Set DB_DRIVER=sqlite in .env and rerun josix db:init if you want a SQLite file.\n");
            exit(1);
        }

        $dbPath = (string) (readEnvValue($envFile, 'DB_PATH') ?? 'database/josix.sqlite');
        if ($dbPath === '' || $dbPath === ':memory:') {
            $dbPath = 'database/josix.sqlite';
        }

        $absoluteDbPath = str_starts_with($dbPath, '/') ? $dbPath : $rootDir . '/' . $dbPath;
        $dbDir          = dirname($absoluteDbPath);

        if (!is_dir($dbDir)) {
            mkdir($dbDir, 0755, true);
        }

        if (!is_file($absoluteDbPath)) {
            touch($absoluteDbPath);
            fwrite(STDOUT, "Created SQLite file: {$absoluteDbPath}\n");
        } else {
            fwrite(STDOUT, "SQLite file already exists: {$absoluteDbPath}\n");
        }

        exit(0);

    case 'live':
        $cmd = 'cd ' . escapeshellarg($rootDir) . ' && ' .
            '(docker compose up -d || docker-compose up -d)';

        fwrite(STDOUT, "Starting Josix Framework Docker stack in {$rootDir}...\n");
        break;

    case 'restart':
        $cmd = 'cd ' . escapeshellarg($rootDir) . ' && ' .
            '((docker compose down || docker-compose down) && (docker compose up -d || docker-compose up -d))';

        fwrite(STDOUT, "Restarting Josix Framework Docker stack in {$rootDir}...\n");
        break;

    case 'stop':
        $cmd = 'cd ' . escapeshellarg($rootDir) . ' && ' .
            '(docker compose down || docker-compose down)';

        fwrite(STDOUT, "Stopping Josix Framework Docker stack in {$rootDir}...\n");
        break;
}

passthru($cmd, $exitCode);

if ($exitCode !== 0) {
    fwrite(STDERR, "Docker command failed (exit code {$exitCode}).\n");
    exit($exitCode);
}

if ($command === 'live' || $command === 'restart') {
    fwrite(STDOUT, "Waiting for the application to become available...\n");

    $url       = 'http://localhost/';
    $maxWait   = 20; // seconds
    $interval  = 2;  // seconds between retries
    $elapsed   = 0;
    $healthy   = false;

    while ($elapsed < $maxWait) {
        sleep($interval);
        $elapsed += $interval;

        $context = stream_context_create(['http' => ['timeout' => 2, 'ignore_errors' => true]]);
        $response = @file_get_contents($url, false, $context);

        if ($response !== false) {
            $healthy = true;
            break;
        }
    }

    if ($healthy) {
        fwrite(STDOUT, "\033[32m✔ Josix Docker stack is running and responding.\033[0m\n");
        fwrite(STDOUT, "Open {$url} in your browser.\n");
    } else {
        fwrite(STDERR, "\033[31m✘ Josix Docker stack started but the application is not responding at {$url}.\033[0m\n");
        fwrite(STDERR, "Check container logs: docker compose logs josix_example\n");
        exit(1);
    }
} else {
    fwrite(STDOUT, "Josix Docker stack has been stopped.\n");
}

